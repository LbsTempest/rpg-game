; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RPG Game"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameConstants="*res://scripts/constants.gd"
ContentDB="*res://scripts/content/content_db.gd"
Session="*res://scripts/core/session.gd"
App="*res://scripts/core/app.gd"
Utils="*res://scripts/utils.gd"
SaveService="*res://scripts/core/save_service.gd"
GameEvents="*res://scripts/core/game_events.gd"
StoryService="*res://scripts/narrative/story_service.gd"
ConditionService="*res://scripts/services/condition_service.gd"
ActionExecutor="*res://scripts/services/action_executor.gd"
TriggerRouter="*res://scripts/services/trigger_router.gd"
UIRouter="*res://scripts/core/ui_router.gd"
InputRouter="*res://scripts/core/input_router.gd"
MapService="*res://scripts/world/map_service.gd"
MovementService="*res://scripts/world/movement_service.gd"
InteractionRegistry="*res://scripts/world/interaction_registry.gd"
SpawnService="*res://scripts/world/spawn_service.gd"
RewardService="*res://scripts/progression/reward_service.gd"
QuestService="*res://scripts/progression/quest_service.gd"
ShopService="*res://scripts/progression/shop_service.gd"
CycleService="*res://scripts/progression/cycle_service.gd"
InventoryService="*res://scripts/services/inventory_service.gd"
BattleService="*res://scripts/battle/battle_service.gd"
DialogueService="*res://scenes/ui/dialogue_screen.tscn"
SkillService="*res://scripts/services/skill_service.gd"
AudioManager="*res://scripts/audio_manager.gd"
EnemyStateService="*res://scripts/world/enemy_state_service.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

